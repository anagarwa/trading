# Broker switch — set to "kite" or "breeze"
ACTIVE_BROKER=kite

# Zerodha Kite Connect
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=your_access_token_here
# Auto-set by token_exchange.yml workflow — do not edit manually
KITE_TOKEN_DATE=

# ICICI Direct Breeze Connect
BREEZE_API_KEY=your_api_key_here
BREEZE_API_SECRET=your_api_secret_here
BREEZE_SESSION_TOKEN=your_session_token_here

# Capital settings
INITIAL_BUDGET=10000

# Optional: Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dry run mode — set to "true" to log decisions without placing real orders
DRY_RUN=false

# Kite token automation (set by the token_exchange GitHub Actions workflow)
# KITE_ACCESS_TOKEN and KITE_TOKEN_DATE are auto-updated daily — do not edit manually.

# Risk thresholds (optional overrides)
STOP_LOSS_PCT=1.5
PROFIT_TARGET_PCT=2.5
EOD_LOSS_THRESHOLD=0.5
MAX_SINGLE_TRADE_PCT=80
